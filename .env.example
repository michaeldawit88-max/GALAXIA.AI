# Galaxia AI - Environment Configuration
# Copy this file to .env and fill in your keys

# Server
PORT=3001
NODE_ENV=development

# Firebase Admin SDK (for Auth)
# Create a service account in Firebase Console > Project Settings > Service Accounts
# Generate a new private key, copy the entire JSON, and base64-encode it:
#   cat firebase-service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_B64=

# OpenAI API Key (for tactical/psychological/negotiation replies)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Deepgram API Key (for real-time STT + diarization)
# https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Turso Database URL + Auth Token (for usage tracking)
TURSO_DB_URL=
TURSO_AUTH_TOKEN=